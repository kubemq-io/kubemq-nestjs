 * unhandled exceptions.
 *
 * @see {@link KubeMQError}
 */
declare class HandlerError extends KubeMQError {
    readonly category: "Fatal";
    constructor(options: KubeMQErrorOptions);
}

/**
 * Connection lifecycle states.
 *
 * Transition diagram:
 *   IDLE ──> CONNECTING ──> READY
 *     ^          │             │
 *     │          v             v
 *     │    RECONNECTING ──> READY
 *     │      │  ↺ (self)
 *     v      v
 *       CLOSED (terminal)
