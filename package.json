{
  "name": "@kubemq/nestjs-transport",
  "version": "1.0.0",
  "description": "KubeMQ transport for NestJS microservices — Commands, Queries, Events, EventsStore, and Queues",
  "license": "MIT",
  "author": "KubeMQ <info@kubemq.io>",
  "homepage": "https://github.com/kubemq-io/kubemq-nestjs-transport",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubemq-io/kubemq-nestjs-transport.git"
  },
  "bugs": {
    "url": "https://github.com/kubemq-io/kubemq-nestjs-transport/issues"
  },
  "keywords": [
    "kubemq",
    "nestjs",
    "microservices",
    "transport",
    "message-queue",
    "cqrs",
    "event-sourcing",
    "pubsub",
    "rpc"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      },
      "require": {
        "types": "./dist/testing.d.cts",
        "default": "./dist/testing.cjs"
      }
    },
    "./cqrs": {
      "import": {
        "types": "./dist/cqrs.d.ts",
        "default": "./dist/cqrs.js"
      },
      "require": {
        "types": "./dist/cqrs.d.cts",
        "default": "./dist/cqrs.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/microservices": "^10.0.0 || ^11.0.0",
    "@nestjs/terminus": "^10.0.0 || ^11.0.0",
    "@nestjs/cqrs": "^10.0.0 || ^11.0.0",
    "kubemq-js": "^3.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.2",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/terminus": {
      "optional": true
    },
    "@nestjs/cqrs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/cqrs": "^11.0.0",
    "kubemq-js": "^3.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "typescript": "^5.5.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^10.0.0",
    "@eslint/js": "^10.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.0.0"
  }
}
